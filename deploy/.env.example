# Copy this file to /opt/podcast-relay/.env and fill in real values.
# Keep it mode 600, owned by the deploy user.
#
# Generate TOKEN with: openssl rand -hex 32

# Only bind to loopback — Caddy is the public-facing process.
HOST=127.0.0.1
PORT=8080

# Shared secret. Clients must pass ?token=... on connect.
TOKEN=REPLACE_ME_32_BYTE_HEX

# Comma-separated list of origins allowed to connect.
# Include both Mike's Electron app and Cretched's extension.
# Electron file:// origin appears as "null" — include it for local testing.
ALLOWED_ORIGINS=https://podcast.example.com,chrome-extension://YOUR_EXTENSION_ID_HERE,null

# Abuse caps.
MAX_PAYLOAD_BYTES=8388608       # 8 MB per message
MAX_MSGS_PER_MIN=30             # per-sender rate limit
MAX_CONNS_PER_IP=5              # per remote IP
PING_INTERVAL_MS=30000          # keepalive ping cadence
